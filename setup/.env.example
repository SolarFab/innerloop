# ─── Innerloop configuration ───────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit real values.

# ── Database (Neon or Supabase — any Postgres over HTTP) ────────────────────
# The Neon "SQL over HTTP" endpoint (Neon dashboard → your project → SQL).
NEON_SQL_URL=https://YOUR-NEON-ENDPOINT.neon.tech/sql
# READ-ONLY role connection string — used by the dashboard API only.
NEON_CONN=postgresql://dashboard_ro:PASSWORD@YOUR-NEON-HOST/neondb?sslmode=require
# OWNER (read/write) connection string — used by the n8n write workflows only. Keep it server-side.
NEON_OWNER_CONN=postgresql://USER:PASSWORD@YOUR-NEON-HOST/neondb?sslmode=require

# ── Dashboard login wall (Vercel edge middleware) ──────────────────────────
BASIC_AUTH_USER=pick_a_username
BASIC_AUTH_PASS=pick_a_strong_password

# ── LibreLinkUp (CGM source) — used inside the n8n "blood sugar tracker" ────
# Your LibreLinkUp login (the app you use to follow your Libre sensor).
LIBRELINKUP_EMAIL=you@example.com
LIBRELINKUP_PASSWORD=your_librelinkup_password
# Account-Id: sha256 of your LibreLinkUp account id. Grab it from the /llu/connections
# response headers, or compute it once — see SETUP.md.
LIBRELINKUP_ACCOUNT_ID=your_librelinkup_account_id
# Regional API host: api-de (EU), api-us (US), api (global). Match your account region.
LIBRELINKUP_API=https://api-de.libreview.io

# ── Telegram (meal-logging bot for the OpenClaw agent) ─────────────────────
TELEGRAM_BOT_TOKEN=from_@BotFather

# ── LLM (OpenClaw agent: vision for food photos + chat) ────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# or OPENAI_API_KEY=sk-...
